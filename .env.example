# x.pink / business@xjoy.ai (Mailhostbox)
MAIL_XJOY_USER=business@xjoy.ai
MAIL_XJOY_PASSWORD=
MAIL_XJOY_IMAP_HOST=us3.imap.mailhostbox.com
MAIL_XJOY_IMAP_PORT=993
MAIL_XJOY_IMAP_SECURE=true
MAIL_XJOY_SMTP_HOST=us3.smtp.mailhostbox.com
MAIL_XJOY_SMTP_PORT=587
MAIL_XJOY_SMTP_SECURE=false

# KISSLY / business@kissly.ai
# MX currently points to mail.emb666.com; confirm the IMAP/SMTP host with the mailbox administrator.
MAIL_KISSLY_USER=business@kissly.ai
MAIL_KISSLY_PASSWORD=
MAIL_KISSLY_IMAP_HOST=mail.emb666.com
MAIL_KISSLY_IMAP_PORT=993
MAIL_KISSLY_IMAP_SECURE=true
MAIL_KISSLY_SMTP_HOST=mail.emb666.com
MAIL_KISSLY_SMTP_PORT=587
MAIL_KISSLY_SMTP_SECURE=false

# Required by GET /api/mailboxes/:id/messages. Use a long random value.
MAIL_READ_API_TOKEN=

# Required by POST /api/mailboxes/:id/send. Use a different long random value.
MAIL_SEND_API_TOKEN=
